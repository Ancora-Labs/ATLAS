{
  "name": "box-orchestrator",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "author": "Ancora Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ancora-Labs/ATLAS.git"
  },
  "description": "Repo-agnostic autonomous engineering orchestrator starter",
  "scripts": {
    "build": "npm run typecheck",
    "lint": "eslint src/",
    "test": "node --import tsx scripts/run_tests.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "box:on": "node --import tsx src/cli.ts on",
    "box:off": "node --import tsx src/cli.ts off",
    "box:up": "pwsh -NoProfile -File scripts/box-up.ps1",
    "box:down": "pwsh -NoProfile -File scripts/box-down.ps1",
    "box:start": "node --import tsx src/cli.ts start",
    "box:stop": "node --import tsx src/cli.ts stop",
    "box:rebase": "node --import tsx src/cli.ts rebase",
    "box:park": "node --import tsx scripts/box_park.ts",
    "box:once": "node --import tsx src/cli.ts once",
    "box:log": "pwsh -NoProfile -File scripts/watch-live-log.ps1",
    "prometheus:watch": "node --import tsx scripts/watch_prometheus_live.ts",
    "worker:run": "node --import tsx src/workers/run_task.ts",
    "doctor": "node --import tsx src/cli.ts doctor",
    "atlas:desktop": "npm run atlas:desktop:package",
    "atlas:desktop:build": "node --import tsx scripts/prepare_atlas_icon_assets.ts && electron-builder --dir && node --import tsx scripts/patch_atlas_exe_icons.ts",
    "atlas:desktop:package": "npm run atlas:desktop:build && node --import tsx scripts/package_atlas_desktop_folder.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "electron": "^36.9.5",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ancora.atlas",
    "productName": "ATLAS",
    "asarUnpack": [
      "node_modules/esbuild/**/*",
      "node_modules/@esbuild/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**",
      "electron/**",
      ".github/agents/**",
      "node_modules/**",
      "atlas.ico",
      "atlasimage.png",
      "atlas.png",
      "atlaslogoii.png",
      "Frame 5.png"
    ],
    "win": {
      "target": "portable",
      "signAndEditExecutable": false,
      "icon": "atlas.ico"
    }
  }
}