{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".electron-build",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "electron/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "state",
    "tests"
  ]
}
